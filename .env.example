# JURINMAP backend — 환경변수 템플릿
# 이 파일은 키 이름만 commit. 실제 값은 .env (gitignore) 에 채울 것.
#
# 로컬 docker 사용 시: cp .env.example .env → 값 채우기 → docker compose up

# ─── [필수] KIS Open Trading API ──────────────────────────────
# 한국투자증권 OpenAPI — 실전투자 계정 기준
# https://apiportal.koreainvestment.com/intro
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCESS_TOKEN=

# ─── [필수] Postgres ──────────────────────────────────────────
# docker compose 의 postgres 컨테이너에 맞춤. 외부 DB 쓰면 host/credentials 변경.
PGHOST=postgres
PGPORT=5432
PGDATABASE=jurinmap
PGUSER=jurinmap
PGPASSWORD=changeme
PGSSLMODE=disable

# ─── [필수] Redis ─────────────────────────────────────────────
# 시세 캐시 · dedupe · 가격 알림 등에 사용. docker compose 의 redis 컨테이너.
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_KEY_PREFIX=jurin:
# Redis URL 형식 (host/port 와 함께 또는 단독)
# REDIS_URL=redis://:password@host:6379/0

# ─── [선택] DART API ──────────────────────────────────────────
# 공시 데이터. 비워두면 dart 관련 기능 일부 동작 안 함.
DART_API_KEY=

# ─── [선택] Gemini (뉴스/기업 AI 분석) ───────────────────────
# scrapers/ai_analysis_engine.py · company_ai_summarizer.py · telemsg.py 가 사용.
# 비워두면 해당 AI 분석 기능 비활성화.
GEMINI_API_KEY=

# ─── [선택] Telegram (telemsg.py 뉴스 수집 봇) ───────────────
# https://my.telegram.org 에서 발급. 비워두면 telemsg.py 동작 안 함.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# ─── [선택] Firebase (FCM 푸시) ───────────────────────────────
# 푸시 알림 발송 시 필요. 서비스 계정 JSON 파일 경로.
# 도커 볼륨으로 마운트: -v ./secrets/firebase.json:/secrets/firebase.json:ro
FIREBASE_SERVICE_ACCOUNT_KEY=/secrets/firebase-service-account.json

# 외부 푸시 트리거 헤더 토큰 (예: /api/push/news 호출 보호)
TELEMSG_PUSH_TOKEN=

# ─── [선택] 미국 데이터 ─────────────────────────────────────
FMP_API_KEY=
FINNHUB_API_KEY=

# ─── [선택] CORS / 보안 ─────────────────────────────────────
# 개발: CORS_OPEN=true (모든 origin 허용)
# 운영: CORS_OPEN=false + CORS_ALLOW_ORIGINS 명시
CORS_OPEN=true
CORS_ALLOW_ORIGINS=https://jurinmap.com,https://www.jurinmap.com

# API key 인증 (선택)
API_SHARED_KEY=

# ─── [선택] 데이터 파이프라인 ───────────────────────────────
DATA_PIPELINE_ENABLED=1
DATA_PIPELINE_TIMEZONE=Asia/Seoul
DATA_PIPELINE_INVESTOR_TIME=16:30
DATA_PIPELINE_DART_TIME=17:00
DATA_PIPELINE_FINANCIALS_TIME=17:30
DATA_PIPELINE_WARN_HOURS=9,16

# 글로벌 매크로 5분 주기 sync (WTI/BRENT/GOLD/VIX/US10Y/SP500/SOX 등 27개 심볼).
# 2026-05-15: 기본 ON. 부하 줄이려면 0 으로.
# PIPELINE_GLOBAL_INDICATORS=1

# ─── [선택] 브리핑 푸시 자동 발송 ──────────────────────────
# 0 으로 두면 brief upsert 후 푸시 안 보냄 (테스트용)
BRIEF_PUSH_ENABLED=1
